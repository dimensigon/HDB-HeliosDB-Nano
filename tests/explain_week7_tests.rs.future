#[test]
fn test_dist_01_cluster_topology() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();

    assert_eq!(result.cluster_nodes.len(), 5); // 1 coordinator + 4 workers
    assert_eq!(result.parallelism_degree, 4);
}

#[test]
fn test_dist_02_partition_info() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();

    assert!(!result.partitions.is_empty());
    assert_eq!(result.partitions.len(), 16); // 16 partitions per table
}

#[test]
fn test_dist_03_partition_pruning() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();

    assert!(result.partition_pruning.is_some());
    let pruning = result.partition_pruning.unwrap();
    assert!(pruning.pruned_partitions > 0);
}

#[test]
fn test_dist_04_pruning_efficiency() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();

    let pruning = result.partition_pruning.unwrap();
    assert!(pruning.pruning_efficiency > 0.0);
}

#[test]
fn test_dist_05_network_operations() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();

    assert!(!result.network_operations.is_empty());
    assert!(result.total_network_cost_ms > 0.0);
}

#[test]
fn test_dist_06_data_transfer() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();

    assert!(result.total_data_transfer_mb > 0.0);
}

#[test]
fn test_dist_07_distributed_join() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let tables = vec!["users".to_string(), "orders".to_string()];
    let result = analyzer.analyze("SELECT", &tables, true, false).unwrap();

    assert!(!result.cross_partition_joins.is_empty());
}

#[test]
fn test_dist_08_broadcast_join() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let tables = vec!["users".to_string(), "orders".to_string()];
    let result = analyzer.analyze("SELECT", &tables, true, false).unwrap();

    // Check if broadcast candidate is identified
    assert!(result.cross_partition_joins.iter()
        .any(|j| j.broadcast_candidate.is_some()));
}

#[test]
fn test_dist_09_distributed_aggregation() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, true).unwrap();

    // Aggregation should produce shuffle operations
    assert!(result.network_operations.iter()
        .any(|op| matches!(op.operation_type, heliosdb_nano::sql::explain_distributed::NetworkOpType::Shuffle)));
}

#[test]
fn test_dist_10_distributed_transaction() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let result = analyzer.analyze("UPDATE", &["users".to_string()], false, false).unwrap();

    assert!(result.distributed_transaction.is_some());
    let txn = result.distributed_transaction.unwrap();
    assert!(txn.two_phase_commit);
}

#[test]
fn test_dist_11_coordination_overhead() {
    let analyzer = DistributedExplainAnalyzer::new(4);
    let result = analyzer.analyze("UPDATE", &["users".to_string()], false, false).unwrap();

    let txn = result.distributed_transaction.unwrap();
    assert!(txn.coordination_overhead_ms > 0.0);
}

#[test]
fn test_dist_12_compression_enabled() {
    let analyzer = DistributedExplainAnalyzer::new(4).with_compression(true);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();

    assert!(result.network_operations.iter().all(|op| op.compression_enabled));
}

#[test]
fn test_dist_13_compression_disabled() {
    let analyzer = DistributedExplainAnalyzer::new(4).with_compression(false);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();

    assert!(result.network_operations.iter().all(|op| !op.compression_enabled));
}

#[test]
fn test_dist_14_network_bandwidth() {
    let analyzer = DistributedExplainAnalyzer::new(4).with_network_bandwidth(100.0);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();

    // Lower bandwidth should result in higher transfer times
    assert!(result.total_network_cost_ms > 0.0);
}

#[test]
fn test_dist_15_format_output() {
    let analyzer = DistributedExplainAnalyzer::new(2);
    let result = analyzer.analyze("SELECT", &["users".to_string()], false, false).unwrap();
    let output = analyzer.format_output(&result);

    assert!(output.contains("DISTRIBUTED QUERY"));
    assert!(output.contains("CLUSTER TOPOLOGY"));
}

