#[test]
fn test_opt_06_mv_refresh_strategy() {
    let engine = OptimizationEngine::new();
    let result = engine.analyze("SELECT", &["users".to_string()], false, true).unwrap();

    for mv in &result.materialized_views {
        // Should have a defined refresh strategy
        assert!(matches!(
            mv.refresh_strategy,
            heliosdb_nano::sql::explain_optimizer::RefreshStrategy::OnDemand |
            heliosdb_nano::sql::explain_optimizer::RefreshStrategy::Scheduled |
            heliosdb_nano::sql::explain_optimizer::RefreshStrategy::Incremental |
            heliosdb_nano::sql::explain_optimizer::RefreshStrategy::RealTime
        ));
    }
}

