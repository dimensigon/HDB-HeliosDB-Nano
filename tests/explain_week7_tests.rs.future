// ============================================================================
// INTERACTIVE TUNING TESTS (10 tests)
// ============================================================================

#[test]
fn test_int_01_create_session() {
    let tuner = InteractiveQueryTuner::new();
    let session = tuner.create_session("SELECT * FROM users".to_string()).unwrap();

    assert!(!session.session_id.is_empty());
    assert_eq!(session.performance_history.len(), 1);
}

#[test]
fn test_int_02_suggest_optimizations() {
    let tuner = InteractiveQueryTuner::new();
    let session = tuner.create_session("SELECT * FROM users".to_string()).unwrap();
    let suggestions = tuner.suggest_optimizations(&session).unwrap();

    assert!(!suggestions.is_empty());
    assert!(suggestions.len() >= 5);
}

#[test]
fn test_int_03_apply_modification() {
    let tuner = InteractiveQueryTuner::new();
    let mut session = tuner.create_session("SELECT * FROM users".to_string()).unwrap();
    let suggestions = tuner.suggest_optimizations(&session).unwrap();

    session.modifications = suggestions;
    let initial_cost = session.performance_history[0].estimated_cost;

    let snapshot = tuner.apply_modification(&mut session, 1).unwrap();

    assert!(snapshot.estimated_cost < initial_cost);
}

#[test]
fn test_int_04_rollback_modification() {
    let tuner = InteractiveQueryTuner::new();
    let mut session = tuner.create_session("SELECT * FROM users".to_string()).unwrap();
    let suggestions = tuner.suggest_optimizations(&session).unwrap();

    session.modifications = suggestions;
    tuner.apply_modification(&mut session, 1).unwrap();
    tuner.rollback_modification(&mut session, 1).unwrap();

    assert!(!session.modifications[0].applied);
}

#[test]
fn test_int_05_what_if_add_index() {
    let tuner = InteractiveQueryTuner::new();
    let scenario = tuner.explore_what_if("SELECT * FROM users", "add_index").unwrap();

    assert_eq!(scenario.scenario_name, "add_index");
    assert!(scenario.after.estimated_time_ms < scenario.before.estimated_time_ms);
}

#[test]
fn test_int_06_what_if_parallel() {
    let tuner = InteractiveQueryTuner::new();
    let scenario = tuner.explore_what_if("SELECT * FROM users", "parallel_execution").unwrap();

    assert_eq!(scenario.scenario_name, "parallel_execution");
}

#[test]
fn test_int_07_what_if_materialized_view() {
    let tuner = InteractiveQueryTuner::new();
    let scenario = tuner.explore_what_if("SELECT * FROM users", "materialized_view").unwrap();

    assert!(scenario.after.cost < scenario.before.cost);
}

#[test]
fn test_int_08_before_after_comparison() {
    let tuner = InteractiveQueryTuner::new();
    let comparison = tuner.compare_before_after(
        "SELECT * FROM users",
        "SELECT id, name FROM users WHERE id > 100",
    ).unwrap();

    assert!(!comparison.improvements.is_empty());
    assert!(comparison.overall_score > 0.0);
}

#[test]
fn test_int_09_format_session() {
    let tuner = InteractiveQueryTuner::new();
    let session = tuner.create_session("SELECT * FROM users".to_string()).unwrap();
    let output = tuner.format_session(&session);

    assert!(output.contains("INTERACTIVE QUERY TUNING"));
}

#[test]
fn test_int_10_format_what_if() {
    let tuner = InteractiveQueryTuner::new();
    let scenario = tuner.explore_what_if("SELECT * FROM users", "add_index").unwrap();
    let output = tuner.format_what_if(&scenario);

    assert!(output.contains("WHAT-IF SCENARIO"));
}

// ============================================================================
// PRODUCTION API TESTS (8 tests)
// ============================================================================

#[test]
fn test_api_01_explain_query() {
    let mut service = ExplainApiService::new();
    let request = ExplainRequest {
        query: "SELECT * FROM users".to_string(),
        mode: "standard".to_string(),
        format: "json".to_string(),
        options: ExplainOptions::default(),
    };

    let response = service.explain_query(request).unwrap();

    assert!(!response.request_id.is_empty());
    assert!(response.execution_time_ms >= 0.0);
}

#[test]
fn test_api_02_caching() {
    let mut service = ExplainApiService::new().with_cache(true);
    let request = ExplainRequest {
        query: "SELECT * FROM users".to_string(),
        mode: "standard".to_string(),
        format: "json".to_string(),
        options: ExplainOptions::default(),
    };

    let response1 = service.explain_query(request.clone()).unwrap();
    let response2 = service.explain_query(request).unwrap();

    assert_eq!(response1.request_id, response2.request_id);
}

#[test]
fn test_api_03_bulk_analysis() {
    let service = ExplainApiService::new();
    let request = BulkAnalysisRequest {
        queries: vec![
            "SELECT * FROM users".to_string(),
            "SELECT * FROM orders".to_string(),
            "SELECT * FROM products".to_string(),
        ],
        mode: "standard".to_string(),
        output_format: heliosdb_nano::sql::explain_api::BulkOutputFormat::Summary,
    };

    let response = service.bulk_analysis(request).unwrap();

    assert_eq!(response.total_queries, 3);
    assert!(response.summary.avg_cost > 0.0);
}

#[test]
fn test_api_04_bulk_max_queries() {
    let service = ExplainApiService::new();
    let queries: Vec<_> = (0..150).map(|i| format!("SELECT * FROM table{}", i)).collect();

    let request = BulkAnalysisRequest {
        queries,
        mode: "standard".to_string(),
        output_format: heliosdb_nano::sql::explain_api::BulkOutputFormat::Summary,
    };

    let result = service.bulk_analysis(request);
    assert!(result.is_err()); // Should exceed max
}

#[test]
fn test_api_05_scheduled_job() {
    use heliosdb_nano::sql::explain_api::*;

    let service = ExplainApiService::new();
    let job = ScheduledExplainJob {
        job_id: "job_123".to_string(),
        name: "Daily analysis".to_string(),
        query_pattern: "SELECT%".to_string(),
        schedule: CronSchedule {
            expression: "0 2 * * *".to_string(),
            timezone: "UTC".to_string(),
        },
        notification_config: NotificationConfig {
            enabled: true,
            email: Some("admin@example.com".to_string()),
            webhook: None,
            alert_on_regression: true,
        },
        retention_days: 30,
    };

    let job_id = service.create_scheduled_job(job).unwrap();
    assert_eq!(job_id, "job_123");
}

#[test]
fn test_api_06_generate_report() {
    use heliosdb_nano::sql::explain_api::*;

    let service = ExplainApiService::new();
    let request = ReportRequest {
        report_type: ReportType::PerformanceSummary,
        time_range: TimeRange {
            start: 1000000,
            end: 2000000,
        },
        include_graphs: true,
        format: ReportFormat::JSON,
    };

    let report = service.generate_report(request).unwrap();

    assert!(!report.report_id.is_empty());
    assert!(!report.content.is_empty());
}

#[test]
fn test_api_07_monitoring_metrics() {
    let service = ExplainApiService::new();
    let metrics = service.get_monitoring_metrics().unwrap();

    assert!(metrics.avg_query_cost > 0.0);
    assert!(metrics.p95_time_ms > 0.0);
}

#[test]
fn test_api_08_graphql_query() {
    let mut service = ExplainApiService::new();
    let result = service.graphql_query("{ explainQuery { cost } }").unwrap();

    assert!(result.get("data").is_some());
}
